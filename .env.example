# Copy to .env and fill in real values. NEVER commit .env.

# mock = no credentials needed, no network calls to Devin; real = live sessions (costs ACUs)
DEVIN_MODE=mock

# Devin API — create in the Devin app (Settings → API keys).
# v3 service-user key (cog_...) + org id. (v1 fallback needs a separate personal key.)
DEVIN_API_KEY=cog_xxxxxxxxxxxxxxxx
DEVIN_ORG_ID=org_xxxxxxxxxxxxxxxx

# Fine-grained GitHub PAT scoped to the target repo:
# Issues read/write, Pull requests read/write, Contents read.
# Leave unset to use canned mock issues (no GitHub polling).
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxx
GITHUB_REPO=madelinehpark/superset

# Issues carrying this label get dispatched to Devin
ORCHESTRATOR_LABEL=auto-fix

# Hard ACU cap passed to every Devin session
MAX_ACU_LIMIT=5

# Seconds between GitHub polls
POLL_INTERVAL=30
